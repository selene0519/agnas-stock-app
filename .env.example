# ARCFLOW/NEXORA local environment variables
# News uses GNews. NEWS_API_KEY is not required.
GNEWS_API_KEY=
FINNHUB_API_KEY=
DART_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# KIS_CANO=                     # 계좌번호 앞 8자리 (미설정 시 KIS_ACCOUNT_NO 앞 8자리 사용)
# KIS_ACNT_PRDT_CD=              # 계좌상품코드 2자리 (미설정 시 KIS_ACCOUNT_NO 뒤 2자리 사용)
# KIS_IS_MOCK=false              # 모의투자: true, 실전: false
# KIS_BASE_URL=                  # API URL 직접 지정 (기본값 자동 선택)

# 한투 2번째 계좌 (python scripts/sync_kis_holdings.py --prefix KIS_2 --upload)
# KIS_2_APP_KEY=
# KIS_2_APP_SECRET=
# KIS_2_ACCOUNT_NO=
# KIS_2_CANO=

# 토스증권 Open API (https://openapi.tossinvest.com)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# MONE bridge upload
# MONE_USER_TOKEN=               # 로그인 후 개발자도구 > localStorage > mone_user_token
# MONE_BACKEND_URL=https://agnas-stock-app.onrender.com

# Optional: Apify news/data collector
APIFY_TOKEN=
APIFY_NEWS_ACTOR_ID=
SEC_USER_AGENT=

# MONE auth
MONE_FRONTEND_URL=
MONE_AUTH_SECRET=
MONE_ADMIN_ID=
MONE_ADMIN_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Kakao OAuth
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_OAUTH_REDIRECT_URI=
